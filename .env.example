# URL gốc của Backend API (dùng HTTPS để tránh mixed-content khi FE deploy trên HTTPS)
VITE_API_BASE_URL="https://api.skillswap.asia"

# Google OAuth Client ID (dùng cho luồng đăng nhập Google Sign-In)
VITE_GOOGLE_CLIENT_ID=""

# Cloudinary — dùng cho luồng FE upload ảnh/tệp trực tiếp lên Cloudinary
# (unsigned upload preset, không cần API secret ở phía FE)
VITE_CLOUDINARY_CLOUD_NAME=""
VITE_CLOUDINARY_UPLOAD_PRESET=""
